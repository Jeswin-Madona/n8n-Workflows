    {
      "parameters": {
        "jsCode": "const html = $json.data || \"\";\n\n// Remove HTML tags\nconst text = html\n  .replace(/<[^>]*>/g, \"\")\n  .replace(/\\s+/g, \" \")\n  .trim();\n\n// Extract the main job description\nconst match = text.match(/Job Summary:(.*?)Similar jobs/i);\n\nconst cleaned = match\n  ? match[1].trim()\n  : text.substring(0, 8000);\n\nreturn [\n  {\n    json: {\n      cleaned_html: cleaned\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
